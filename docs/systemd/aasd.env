# Example environment file for the sample `docs/systemd/aasd.service` unit.
# Copy this file to `/etc/default/aasd` and adjust the options for your host.

# Use one shell-style string with the daemon command-line flags.
# Typical examples:
# AASD_OPTS="-f /etc/aasd.conf -P /opt/AASd/plugins"
# AASD_OPTS="-d -f /var/tmp/aasd.conf -P /opt/AASd/plugins"
AASD_OPTS="-f /etc/aasd.conf -P /opt/AASd/plugins"
